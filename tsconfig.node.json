{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "checkJs": true,
    "composite": true,
    "noEmit": true
  },
  "include": [
    "./vite.config.ts",
    "./routeNamePlugin.ts",
    "./postcss.config.mjs",
    "./eslint.config.ts",
    "./stylelint.config.mjs"
  ]
}
