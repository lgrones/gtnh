# Firebase web app config — copy to .env.local and fill from the Firebase console
# (Project settings → General → Your apps → SDK setup and configuration).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Realtime Database URL, e.g. https://<project>-default-rtdb.firebaseio.com
VITE_FIREBASE_DATABASE_URL=

# Set to "true" to point the app at the local Firebase emulators (pnpm dev).
VITE_USE_EMULATORS=false
